{
  "name": "better-agent-terminal",
  "version": "1.0.0",
  "description": "Windows terminal aggregator with multi-workspace support and Claude Code integration",
  "author": "Gower",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "cross-env BAT_DEBUG=1 vite",
    "dev-runtime": "cross-env BAT_DEBUG=1 BAT_RUNTIME=1 vite",
    "compile": "vite build",
    "start": "electron .",
    "build": "vite build && electron-builder",
    "build:dir": "vite build && electron-builder --dir",
    "build:release": "node scripts/build-version.js",
    "postinstall": "node -e \"if(process.platform==='darwin'){const p=require('path').join('node_modules/electron/dist/Electron.app/Contents/Info.plist');try{require('child_process').execSync('plutil -replace CFBundleName -string BetterAgentTerminal '+p+' && plutil -replace CFBundleDisplayName -string BetterAgentTerminal '+p)}catch(e){}}\" && npm rebuild better-sqlite3 && echo 'postinstall done'",
    "test:console": "node tests/console-test.js",
    "test:claude-ctrl-o": "node tests/test-claude-ctrl-o.js",
    "test:e2e": "playwright test",
    "diagnose:ctrl-o": "npx electron tests/diagnose-ctrl-o.js",
    "diagnose:ctrl-o:quick": "npx electron tests/diagnose-ctrl-o.js --quick",
    "diagnose:ctrl-o:verbose": "npx electron tests/diagnose-ctrl-o.js --verbose",
    "test:node-resolver": "npx tsx tests/node-resolver.test.ts",
    "test:file-drag": "npx tsx tests/file-drag-to-chat.test.ts",
    "bat-terminal": "node scripts/bat-terminal.mjs"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.111",
    "@anthropic-ai/claude-code": "^2.1.111",
    "@types/dompurify": "^3.0.5",
    "@types/qrcode": "^1.5.6",
    "@xterm/addon-canvas": "^0.7.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-unicode11": "^0.8.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "better-sqlite3": "^12.5.0",
    "dompurify": "^3.3.3",
    "highlight.js": "^11.11.1",
    "i18next": "^25.8.18",
    "js-yaml": "^4.1.1",
    "marked": "^17.0.5",
    "mermaid": "^11.14.0",
    "opencc-js": "^1.0.5",
    "qrcode": "^1.5.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^16.5.8",
    "selfsigned": "^5.5.0",
    "simple-git": "^3.36.0",
    "uuid": "^9.0.0",
    "whisper-node-addon": "^1.0.2",
    "ws": "^8.19.0"
  },
  "optionalDependencies": {
    "@img/sharp-darwin-arm64": "^0.34.5",
    "@img/sharp-darwin-x64": "^0.34.5",
    "@img/sharp-libvips-darwin-arm64": "^1.2.4",
    "@img/sharp-libvips-darwin-x64": "^1.2.4",
    "@lydell/node-pty": "^1.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/uuid": "^9.0.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^8.2.0",
    "cross-env": "^10.1.0",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0",
    "vite": "^7.0.0",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "overrides": {
    "minimatch@3": "3.1.5",
    "minimatch@5": "5.1.9",
    "hono": ">=4.12.12",
    "@hono/node-server": ">=1.19.13",
    "lodash-es": ">=4.18.1",
    "langium": ">=4.2.2"
  },
  "build": {
    "appId": "org.tonyq.better-agent-terminal",
    "productName": "BetterAgentTerminal",
    "executableName": "BetterAgentTerminal",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "BetterAgentTerminal",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon-512.png",
      "category": "public.app-category.developer-tools",
      "identity": "TonyQ CO., LTD. (8JVDJGLLYR)",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": true,
      "extendInfo": {
        "NSDocumentsFolderUsageDescription": "BetterAgentTerminal needs access to your Documents folder to open terminals and manage files in your projects.",
        "NSDesktopFolderUsageDescription": "BetterAgentTerminal needs access to your Desktop folder to open terminals and manage files in your projects.",
        "NSDownloadsFolderUsageDescription": "BetterAgentTerminal needs access to your Downloads folder to open terminals and manage files in your projects.",
        "NSMicrophoneUsageDescription": "better-agent-terminal 需要存取麥克風以提供語音輸入功能，將語音辨識後填入輸入框。/ better-agent-terminal needs microphone access for voice input feature, transcribing speech into the input textarea."
      }
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon-512.png"
    },
    "forceCodeSigning": false,
    "npmRebuild": false,
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "node_modules/**/*",
      "assets/icon.ico",
      "assets/icon.png",
      "assets/icon-512.png"
    ],
    "asarUnpack": [
      "node_modules/@anthropic-ai/claude-code/**/*",
      "node_modules/@anthropic-ai/claude-agent-sdk/**/*",
      "node_modules/@img/**/*",
      "dist-electron/terminal-server.js"
    ],
    "extraResources": [
      {
        "from": "scripts",
        "to": "scripts",
        "filter": [
          "bat-terminal.mjs",
          "bat-notify.mjs"
        ]
      }
    ]
  }
}
